# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real secrets.

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Inbox that contact-form submissions are delivered to
CONTACT_TARGET_EMAIL=

# Upstash Redis — per-IP rate limiting for the contact form.
# https://console.upstash.com → your DB → "REST API" tab.
# Optional: if unset, rate limiting is skipped (honeypot/timing/origin stay on).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
